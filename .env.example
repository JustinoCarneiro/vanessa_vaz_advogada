# =============================================================================
# Vanessa Vaz Marschallinger — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA comite .env.local — ele está no .gitignore.
# =============================================================================

# Banco de dados — Neon PostgreSQL (neon.tech)
# Obtenha em: https://console.neon.tech → Connection string
# Formato: postgresql://user:password@host/database?sslmode=require
DATABASE_URI=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Payload CMS — chave secreta para JWT (mínimo 32 caracteres aleatórios)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=troque-por-string-aleatoria-de-pelo-menos-32-chars

# Resend — API para envio de emails do formulário de contato
# Obtenha em: https://resend.com/api-keys
# Sem esta chave, as mensagens são salvas no painel mas o email não é enviado.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Destinatário dos emails de contato (email da advogada)
CONTACT_EMAIL_TO=vanessavaz8@gmail.com

# URL pública do servidor (usada em metadata, sitemap e OG tags)
# Em produção: https://vvmadvocacia.adv.br (ou o domínio contratado)
# Em desenvolvimento: http://localhost:3000
NEXT_PUBLIC_SERVER_URL=https://vvmadvocacia.adv.br

# =============================================================================
# Apenas para testes E2E com Playwright — não necessário em produção
# =============================================================================
# Crie um usuário admin no painel (/admin) e informe as credenciais aqui.
PLAYWRIGHT_ADMIN_EMAIL=admin@vvmadvocacia.adv.br
PLAYWRIGHT_ADMIN_PASSWORD=
